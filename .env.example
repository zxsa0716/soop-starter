# =============================================================================
# 숲스타터 (Soop Starter) · 환경변수 템플릿
# =============================================================================
# 사용법:
#   1. 이 파일을 `.env`로 복사: cp .env.example .env
#   2. 아래 값을 본인 발급 키로 교체
#   3. .env 파일은 절대 git에 commit 하지 말 것 (.gitignore에 등록됨)
# =============================================================================

# === LLM ===
# Google Gemini API key — https://aistudio.google.com/apikey 에서 발급 (무료)
GEMINI_API_KEY=

# === 공공데이터 API (5종) ===
# 모두 data.go.kr 또는 해당 기관 사이트에서 무료 발급 가능

# 1) 산림자원통계 OpenAPI (산림청)
#    https://www.data.go.kr/data/15086755/openapi.do
KFS_FRSAS1_KEY=

# 2) 토지실거래가 OpenAPI (국토교통부)
#    https://www.data.go.kr/data/15126469/openapi.do
LANDTRADE_API_KEY=

# 3) 기상청 단기예보 OpenAPI
#    https://www.data.go.kr/data/15084084/openapi.do
KMA_FORECAST_API_KEY=

# 4) 기상청 산악기상 (KMA API Hub)
#    https://apihub.kma.go.kr/typ08
KMA_MOUNTAIN_API_KEY=

# 5) 산림사업법인 정보 (산림청)
#    https://www.data.go.kr/data/15068700/openapi.do
KFS_BUSINESS_API_KEY=

# === DB (선택, 로컬 실행 시에만 필요) ===
POSTGRES_URL=
CHROMA_PATH=./data/processed/corpus_reference/chroma_db

# === 법제처 (선택) ===
# https://open.law.go.kr/LSO/openApi/cuAskList.do
LAW_GO_KR_OC=
LAW_GO_KR_KEY=
